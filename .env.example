# =============================================================================
# On Education — variáveis de ambiente (NOMES, sem valores).
# Copie para .env.local (nunca commite .env*). Cada segredo vem do seu provedor.
# =============================================================================

# Ambiente: development | test | production
NODE_ENV=development

# --- Banco de dados (Postgres / Supabase) ------------------------------------
# String de conexão Postgres usada pelo Drizzle e pelos testes de RLS.
# Supabase: Project Settings > Database > Connection string (URI). Use a porta
# 5432 (session) para migrations. Inclua ?sslmode=require em produção.
DATABASE_URL=

# --- Supabase (Auth / Storage) -----------------------------------------------
# Project Settings > API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Chave de serviço (NUNCA expor no client; só server/worker).
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (Anthropic Claude) — usado a partir das fases de IA ------------------
# https://console.anthropic.com/ > API Keys
ANTHROPIC_API_KEY=

# --- Observabilidade (opcional) ----------------------------------------------
# https://sentry.io > Project > Client Keys (DSN). Deixe vazio para desativar.
SENTRY_DSN=
