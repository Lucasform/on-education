# =============================================================================
# On Education — variáveis de ambiente (NOMES, sem valores).
# Copie para .env.local (nunca commite .env*). Cada segredo vem do seu provedor.
# =============================================================================

# Ambiente: development | test | production
NODE_ENV=development

# --- Banco de dados (Postgres / Supabase) ------------------------------------
# String de conexão Postgres usada pelo Drizzle e pelos testes de RLS.
# Supabase: Project Settings > Database > Connection string (URI). Use a porta
# 5432 (session) para migrations. Inclua ?sslmode=require em produção.
DATABASE_URL=
# Tamanho do pool de conexões por instância serverless. Default 1 (seguro no session pooler
# 5432). No TRANSACTION pooler (6543) pode subir (ex.: 5) para as consultas de uma página
# rodarem em paralelo e a navegação ficar rápida. Ex.: DB_POOL_MAX=5
DB_POOL_MAX=

# --- Supabase (Auth / Storage) -----------------------------------------------
# Project Settings > API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Chave de serviço (NUNCA expor no client; só server/worker).
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (Anthropic Claude) — usado a partir das fases de IA ------------------
# https://console.anthropic.com/ > API Keys
ANTHROPIC_API_KEY=

# --- IA (geração de imagem via OpenAI gpt-image-1) — opcional ----------------
# https://platform.openai.com/ > API Keys. Sem ela, a geração de imagem fica
# desativada (gate por entitlement + config). Pay-as-you-go.
OPENAI_API_KEY=
# Teto global de imagens por mês na plataforma inteira (kill-switch de custo).
# Inteiro. Default no código se vazio. Ex.: IMAGE_MONTHLY_GLOBAL_CAP=2000
IMAGE_MONTHLY_GLOBAL_CAP=

# --- Observabilidade (opcional) ----------------------------------------------
# https://sentry.io > Project > Client Keys (DSN). Deixe vazio para desativar.
SENTRY_DSN=

# --- Sessão de desenvolvimento (stopgap até o Supabase Auth) -----------------
# Segredo para assinar a cookie de sessão (HMAC). Gere um valor forte, ex.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Server-only. Será substituído pelo Supabase Auth; não usar em produção sem auth real.
DEV_SESSION_SECRET=

# --- Super-admin (painel /admin) ---------------------------------------------
# E-mails autorizados a abrir o /admin, separados por vírgula. Vazio = /admin trancado.
# Server-only. Ex.: SUPER_ADMIN_EMAILS=voce@exemplo.com,socio@exemplo.com
SUPER_ADMIN_EMAILS=

# WhatsApp (Evolution API) — server-only
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# --- E-mail (Resend) — server-only -------------------------------------------
# https://resend.com > API Keys (chave re_...). Sem ela, os envios de e-mail
# (comunicado a todos, relatório aos pais) ficam desativados.
RESEND_API_KEY=
# Remetente. Sem domínio próprio verificado, use 'onboarding@resend.dev' para testar.
# Com domínio (resend.com/domains): "Sua Escola <contato@suaescola.com.br>".
RESEND_FROM=

# --- Recurso externo: vídeo do YouTube (Fase 2) — opcional -------------------
# https://console.cloud.google.com > YouTube Data API v3 > Credenciais (cota grátis).
# Sem ela, o WayOn simplesmente não sugere vídeo.
YOUTUBE_API_KEY=

# --- Cobrança da assinatura (Stripe) — opcional ------------------------------
# Sem STRIPE_SECRET_KEY o app fica em "ativação imediata" (a tela de Planos ativa o plano
# direto, sem cobrança). Com as chaves, a ativação passa por Stripe Checkout e o webhook
# libera o plano. Painel: https://dashboard.stripe.com
# Chave secreta (sk_test_... em teste, sk_live_... em produção). Server-only.
STRIPE_SECRET_KEY=
# Segredo do webhook (whsec_...). Em Developers > Webhooks > endpoint
#   {APP_PUBLIC_URL}/api/billing/webhook   (eventos: checkout.session.completed,
#   customer.subscription.created, customer.subscription.updated, customer.subscription.deleted).
STRIPE_WEBHOOK_SECRET=
# URL pública do app para success/cancel do checkout. Ex.: https://on-education-seven.vercel.app
# Se vazio, usa a origem da requisição.
APP_PUBLIC_URL=
#
# Price IDs (crie 1 Product+Price recorrente/mês no Stripe para cada item e cole o price_...).
# COMBOS (um por plano pago):
STRIPE_PRICE_PLAN_TEACHER_BASIC=
STRIPE_PRICE_PLAN_TEACHER_PRO=
STRIPE_PRICE_PLAN_SCHOOL_STARTER=
STRIPE_PRICE_PLAN_SCHOOL_FULL=
# À LA CARTE (um por funcionalidade — só precisa se for vender avulso):
STRIPE_PRICE_FEATURE_CLASSES_MANAGE=
STRIPE_PRICE_FEATURE_ACTIVITIES_BANK=
STRIPE_PRICE_FEATURE_MARKETPLACE=
STRIPE_PRICE_FEATURE_AI_LESSONPLAN=
STRIPE_PRICE_FEATURE_AI_ACTIVITIES=
STRIPE_PRICE_FEATURE_AI_IMAGES=
STRIPE_PRICE_FEATURE_AI_ESSAYGRADING=
STRIPE_PRICE_FEATURE_COMMUNICATION_LIGHT=
STRIPE_PRICE_FEATURE_COMMUNICATION_MASS=
STRIPE_PRICE_FEATURE_ENROLLMENT_OFFICIAL=
STRIPE_PRICE_FEATURE_ANALYTICS_DIRECTOR=
STRIPE_PRICE_FEATURE_FINANCE_INSTITUTIONAL=

# --- Pagamento da MENSALIDADE (família -> escola) — opcional -----------------
# Camada AGNÓSTICA de PSP, distinta do Stripe (que cobra a assinatura do SaaS).
# Sem PAYMENTS_PROVIDER + chave, o portal mantém o comportamento de hoje (2ª via
# read-only, baixa manual pela secretaria). Ver docs/SETUP-PAGAMENTOS.md.
# Provedor escolhido: asaas | iugu. Vazio = desligado. Server-only.
PAYMENTS_PROVIDER=
# Asaas (https://docs.asaas.com) — access_token da conta (sandbox ou produção).
ASAAS_API_KEY=
# Token que o Asaas envia no header `asaas-access-token` do webhook (autenticação).
ASAAS_WEBHOOK_TOKEN=
# Iugu (https://dev.iugu.com) — API token da conta.
IUGU_API_KEY=
# Token combinado para autenticar o webhook da Iugu.
IUGU_WEBHOOK_TOKEN=
# Webhook do PSP (em ambos): {APP_PUBLIC_URL}/api/payments/webhook

# --- BYOK: criptografia da chave de IA do professor --------------------------
# Segredo p/ criptografar (AES-GCM) a API key que o professor pluga. Se vazio, deriva do
# DEV_SESSION_SECRET. Em produção, defina um valor forte e ESTÁVEL (trocar invalida chaves salvas).
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=
